rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES & VALIDATION HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email in ["rudson.p48@icloud.com", "rudson.p48@gmail.com", "rudson.p48@iclou.com", "ronei7412369@gmail.com"]; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUserCreate(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.email is string && data.email.size() <= 200
        && data.createdAt == request.time
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500))
        && (!('lastLogin' in data) || (data.lastLogin == request.time))
        && (!('isPaid' in data) || data.isPaid is bool)
        && (!('trialEndsAt' in data) || data.trialEndsAt is timestamp);
    }

    function isValidUserUpdate(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500))
        && (!('lastLogin' in data) || (data.lastLogin == request.time))
        && (!('isPaid' in data) || data.isPaid is bool)
        && (!('trialEndsAt' in data) || data.trialEndsAt is timestamp);
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Admin read all, or Owner read self
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      // Admin create all, or Owner self
      allow create: if (isAdmin() || (isSignedIn() && request.auth.uid == userId)) 
        && isValidId(userId)
        && isValidUserCreate(incoming());
        
      // Admin update all, or Owner update self
      allow update: if isAdmin() || (
        isSignedIn()
        && request.auth.uid == userId
        && isValidUserUpdate(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().email == existing().email
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin'])
      );
    }
  }
}
