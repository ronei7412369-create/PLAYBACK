rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES & VALIDATION HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUserCreate(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.email is string && data.email.size() <= 200
        && data.createdAt == request.time
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500))
        && (!('lastLogin' in data) || (data.lastLogin == request.time));
    }

    function isValidUserUpdate(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500))
        && (!('lastLogin' in data) || (data.lastLogin == request.time));
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Owner only read
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Owner create
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUserCreate(incoming());
        
      // Owner update
      allow update: if (
        isSignedIn()
        && request.auth.uid == userId
        && isValidUserUpdate(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().email == existing().email
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin'])
      );
    }
  }
}
